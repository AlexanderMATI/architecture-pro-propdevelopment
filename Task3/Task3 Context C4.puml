@startuml
!include <C4/C4_Container>

skinparam {
    backgroundColor #FAFAFA
    roundCorner 20
    shadowing true
    wrapWidth 200
}

Person(owner, "Собственник", "Владелец жилья, использующий мобильное приложение для управления умными устройствами")

System(propdev_system, "Система PropDevelopment", "Существующая система, включающая мобильное приложение для собственников и бэкенд-сервисы")
System_Ext(partner_smarthome_system, "Система 'Умный дом' партнёра", "Внешняя система, предоставляющая API для управления домофоном и шлагбаумом, а также обрабатывающая биометрию и распознавание номеров")
System_Ext(intercom, "Интеллектуальный домофон", "Физическое устройство с функцией распознавания лиц и возможностью звонка")
System_Ext(barrier, "Интеллектуальный шлагбаум", "Физическое устройство с функцией распознавания номеров автомобилей")

Rel(owner, propdev_system, "Управляет доступом (добавляет/удаляет пользователей, номера авто) и просматривает события через мобильное приложение")
Rel(propdev_system, partner_smarthome_system, "Отправляет команды на управление доступом и получает статусы устройств", "API (REST/JSON)")
Rel_Back(propdev_system, partner_smarthome_system, "Получает уведомления о событиях (открытие двери, въезд автомобиля)", "Webhooks")
Rel(partner_smarthome_system, intercom, "Отправляет команды на открытие двери и управляет базой биометрических данных")
Rel(partner_smarthome_system, barrier, "Отправляет команды на открытие шлагбаума и управляет базой разрешённых номеров")

Rel_Back(intercom, partner_smarthome_system, "Передаёт данные для распознавания лиц и информацию о звонках")
Rel_Back(barrier, partner_smarthome_system, "Передаёт данные для распознавания номеров автомобилей")

@enduml